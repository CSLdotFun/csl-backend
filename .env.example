# Price source: mock | skinport | lisskins
#   mock     — simulated live prices (default, no setup)
#   skinport — FREE, no key, no deposit (recommended for real prices)
#   lisskins — lis-skins Public User API (needs key + $100 balance)
SOURCE=mock

# --- lis-skins (only if SOURCE=lisskins) ---
LIS_SKINS_API_KEY=
LIS_SKINS_BASE_URL=https://api.lis-skins.com
LIS_SKINS_GAME=csgo
LOG_RAW=0

# Poll interval ms (auto: mock 1500 / skinport 300000 / lisskins 20000)
POLL_INTERVAL_MS=

# Candle interval seconds (default 60 = 1m)
CANDLE_TF_SEC=60
# Funding interval seconds (default 3600 = 1h)
FUNDING_INTERVAL_SEC=3600

# CORS: your Vercel origin, e.g. https://www.csl.fun (default * for testing)
CORS_ORIGIN=*
# Railway injects PORT; local default 8080
PORT=8080

# Real daily price history (up to ~365d, Steam Market) — free key, no deposit:
# https://www.steamwebapi.com → sign up → dashboard → API key
STEAMWEBAPI_KEY=

# --- accounts & trading (server-side) ---
# Postgres (Railway: add PostgreSQL, then reference its DATABASE_URL here)
DATABASE_URL=
# Privy server verification
PRIVY_APP_ID=cmr6oo33w00w00cjxl9thvmh3
PRIVY_APP_SECRET=
# Risk caps (conservative beta defaults)
MAX_LEVERAGE=20
MAX_COLLATERAL_PER_POSITION=250
MAX_POSITIONS_PER_USER=10
MAX_OI_PER_MARKET=10000
# house-wide notional cap across ALL positions (total risk ceiling)
MAX_TOTAL_OI=50000
# liquidate this fraction early to limit bad debt on gaps (0.004 = 0.4%)
LIQ_BUFFER=0.004
# ignore marks older than this many ms when liquidating (frozen-oracle guard)
PRICE_MAX_AGE_MS=120000

# --- price oracle (multi-source median + TWAP) ---
# drop a source if it deviates more than this from the group median (0.08 = 8%)
ORACLE_OUTLIER_DEV=0.08
# TWAP window: how long the mark takes to absorb a sustained spot move (ms)
ORACLE_TWAP_WINDOW_MS=60000
# a mark older than this is stale → engine skips liquidations on it (ms)
ORACLE_MARK_STALE_MS=180000
# minimum sources that must return a price for a fresh spot to be accepted
ORACLE_MIN_SOURCES=1

# --- second oracle source: CSFloat (public reads, no key required) ---
# All CS2 skins trade here incl. Dragon Lore/Howl. Rate-limited, so prices
# refresh a few items per tick in the background and are cached. Combined with
# Skinport this gives a real 2-source median. Optional CSFLOAT_API_KEY raises
# the rate limit if you have one.
CSFLOAT=1
CSFLOAT_API_KEY=
CSFLOAT_TTL_MS=480000
CSFLOAT_SPACING_MS=2500
CSFLOAT_BATCH=5

# --- settlement (deposits / withdrawals) — set at launch ---
RPC_URL=
DEPOSIT_MASTER_SEED=
TREASURY_ADDRESS=
TREASURY_SECRET=
MIN_WITHDRAW=5
MAX_AUTO_WITHDRAW=100
MAX_DEPOSIT_PER_USER=500
# withdrawal rate limits (drain protection)
MAX_WITHDRAW_PER_USER_DAY=500
MAX_WITHDRAWS_PER_USER_DAY=10
MAX_WITHDRAW_HOUSE_HOUR=1000
VAULT_OPEN=0

# --- admin (protects /api/admin/* ) ---
# long random string; send as header X-Admin-Token to hit admin endpoints
ADMIN_TOKEN=
